# =============================================================================
# Easy-to-edit config for evaluating the DINOv2-cached @ 252 + goal-compass IL
# checkpoint on the single-scene MP3D 6-cat subset.  Source'd by
# scripts/eval_il_mp3d_1scene_full.sh.
#
# The variant evaluated here was trained by reading precomputed DINOv2 CLS
# features from data/dinov2_cache_poses_252_poses/<scene>/<episode_id>.pt
# (252x252, pose-replay precompute) AND the live oracle GoalCompassSensor
# (cheap, no cache).  Rollout collection used IL.BehaviorCloning.REPLAY_MODE=
# poses (teleport to recorded agent_state).
#
# For *eval* we do NOT use the DINOv2 cache (val split has no cache; eval must
# also work on unseen episodes).  Instead we evaluate via the online DINOv2
# encoder + live goal-compass, which runs the exact same resize-to-252x252 +
# ImageNet preprocessing and the same frozen facebook/dinov2-base backbone that
# built the cache, so this is apples-to-apples with training.
# =============================================================================

# Online-DINOv2 + goal-compass experiment config (no CACHED_DINOV2_SENSOR;
# GOAL_COMPASS_SENSOR is still enabled).  Its yaml pins dinov2_resize_h/w = 252,
# matching the cache the checkpoint was trained against.  Policy weights come
# from EVAL_CKPT; frozen DINOv2 weights are pulled from HuggingFace at
# construction time.
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_goalcompass.yaml}"

# Final checkpoint from the 252 pose-replay cached + goal-compass run.
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_cached_252_gc/objectnav_il/mp3d_1scene_6cat_dinov2_cached_252_gc/ckpt.10.pth}"

# Which splits to evaluate on.
# "train" = episodes the model trained on (measures overfit).
# "val"   = held-out episodes from same scene (measures generalisation).
: "${EVAL_SPLITS:=train val}"

# How many episodes per split.  -1 = all (302 for train, 53 for val).
: "${TEST_EPISODE_COUNT:=-1}"

# Concurrent habitat-sim envs during eval.  Keep at 1 so the VectorEnv
# episode iterator doesn't silently drop episodes at split boundaries.
: "${NUM_ENVIRONMENTS:=1}"

# --- Task-config overrides (CRITICAL for a meaningful eval) ----------------
# Match the training-time demonstration recording: 1.0m success distance,
# sliding enabled.  Pose-replay training bypasses sim physics, so the policy
# never saw sliding during training -- but eval uses discrete actions through
# sim physics, and we want to compare to what the expert demos achieved.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

# --- Video recording -------------------------------------------------------

# If false, no videos are written at all (fastest).
: "${VIDEO_ENABLED:=false}"

# If true, only episodes where the agent FAILED (success<0.5) get a video.
: "${VIDEO_FAILED_ONLY:=false}"

# Frames per second for the saved mp4 files.
: "${VIDEO_FPS:=10}"

# If true, overlays the top-down map + trajectory + collisions onto each frame.
: "${VIDEO_RENDER_TOP_DOWN:=true}"

# --- Output layout ---------------------------------------------------------

: "${OUT_ROOT:=data/eval_out/dinov2_cached_252_gc_ckpt10}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING
