# =============================================================================
# Eval config for the oracle-trained DINOv2 + object-cloud checkpoint with the
# goal-compass auxiliary loss head, evaluated with the precomputed per-scene
# object cloud loaded at eval time (matches train).  Source'd by
# scripts/eval_il_mp3d_1scene_full.sh.
#
# CONFIG points at the online-DINOv2 + object-cloud base yaml so that DINOv2
# runs live from the RGB frame -- val episodes have no precomputed cache files
# so CachedDINOv2Sensor would crash.  EXTRA_OPTS re-enables the compass-aux
# policy architecture flags and switches the object cloud sensor to cached
# mode, exactly mirroring what eval_dinov2_oracle_object_cloud.env does for the
# plain oracle-cloud baseline.  GOAL_COMPASS_SENSOR is included so the GT
# compass panel appears in eval videos alongside the predicted one.
# =============================================================================

# Use the online-DINOv2 + object-cloud base yaml so that:
#   1. DINOv2 runs live from the RGB frame (no precomputed cache needed at
#      eval time -- val episodes have no cached features).
#   2. EXTRA_OPTS re-enables the compass-aux policy flags and switches the
#      object cloud sensor to cached mode, matching the training setup.
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_object_cloud.yaml}"

# Final checkpoint from the oracle-cloud + compass-aux training run.
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_oracle_object_cloud_compass_aux/objectnav_il/mp3d_1scene_6cat_dinov2_oracle_object_cloud_compass_aux/ckpt.10.pth}"

: "${EVAL_SPLITS:=train val}"
: "${TEST_EPISODE_COUNT:=-1}"
: "${NUM_ENVIRONMENTS:=1}"

# Match the existing cached-cloud eval setup so numbers are comparable.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

: "${VIDEO_ENABLED:=true}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

: "${OUT_ROOT:=data/eval_out/dinov2_oracle_object_cloud_compass_aux_ckpt10}"

# Architecture overrides required by this checkpoint -- always appended to
# whatever the user passes via EXTRA_OPTS so the user can supply per-run
# tweaks (e.g. POLICY.RGB_ENCODER.use_augmentations_test_time False) without
# having to re-type these.  Appending at the end means YACS applies the
# architecture overrides last, so the user can never accidentally turn off
# compass_aux_loss or restore the wrong sensor list.
#
# Why each override is needed:
#   - compass_aux_loss True: must match the trained checkpoint architecture
#     (12-D compass head, goal-conditioned encoder, compass_proj into GRU).
#   - EGO_OBJECT_CLOUD_SENSOR.CACHE_ROOT: switches the cloud sensor to cached
#     mode (matches training); without it the sensor would try to build the
#     cloud online from depth+semantic, which aren't available below.
#   - TASK_CONFIG.TASK.SENSORS: drops CACHED_DINOV2_SENSOR (val episodes have
#     no precomputed features) and adds GOAL_COMPASS_SENSOR for the GT panel.
#   - SENSORS ["RGB_SENSOR"]: top-level; habitat-lab copies it into
#     SIMULATOR.AGENT_0.SENSORS, dropping depth/semantic framebuffer passes
#     that the cached cloud branch never reads.
EXTRA_OPTS="${EXTRA_OPTS:-} POLICY.OBJECT_CLOUD_ENCODER.compass_aux_loss True TASK_CONFIG.TASK.EGO_OBJECT_CLOUD_SENSOR.CACHE_ROOT data/object_clouds/mp3d TASK_CONFIG.TASK.SENSORS [\"OBJECTGOAL_SENSOR\",\"COMPASS_SENSOR\",\"GPS_SENSOR\",\"EGO_OBJECT_CLOUD_SENSOR\",\"GOAL_COMPASS_SENSOR\"] SENSORS [\"RGB_SENSOR\"]"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING EXTRA_OPTS
