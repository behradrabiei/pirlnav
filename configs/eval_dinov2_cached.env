# =============================================================================
# Easy-to-edit config for evaluating the DINOv2-cached IL checkpoint on the
# single-scene MP3D 6-cat subset.  Source'd by scripts/eval_il_mp3d_1scene_full.sh.
#
# The cached variant was trained by reading precomputed DINOv2 CLS features
# from data/dinov2_cache/17DRP5sb8fy/<episode_id>.pt.  For *eval* we do NOT use
# the cache (we don't have val features); instead we evaluate via the online
# DINOv2 encoder, which runs the exact same center_crop(476,630) + ImageNet
# preprocessing and the same frozen facebook/dinov2-base backbone that built
# the cache, so this is apples-to-apples with the cached training run.
# =============================================================================

# Use the online-DINOv2 experiment config (no CACHED_DINOV2_SENSOR; falls back
# to the online DINOv2 forward path in ObjectNavILMAENet).  The policy's
# trainable weights are loaded from EVAL_CKPT, the frozen DINOv2 weights are
# pulled fresh from HuggingFace at construction time (they were not serialized
# into the checkpoint since they were frozen during training).
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2.yaml}"

# Final checkpoint from the DINOv2-cached run (update 20000).
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_cached/objectnav_il/mp3d_1scene_6cat_dinov2_cached/ckpt.10.pth}"

# Which splits to evaluate on.
# "train" = episodes the model trained on (measures overfit).
# "val"   = held-out episodes from same scene (measures generalisation).
: "${EVAL_SPLITS:=train val}"

# How many episodes per split.  -1 = all (302 for train, 53 for val).
: "${TEST_EPISODE_COUNT:=-1}"

# Concurrent habitat-sim envs during eval.  Keep at 1 so the VectorEnv episode
# iterator doesn't silently drop episodes at split boundaries (we hit this with
# the previous eval runs).
: "${NUM_ENVIRONMENTS:=1}"

# --- Task-config overrides (CRITICAL for a meaningful eval) ----------------
# Match the training-time task spec: 1.0m success distance, sliding enabled.
# These are the values the MP3D demonstrations were recorded with; the
# upstream YAML defaults (0.1m / no-slide) make the expert itself fail ~75%
# of the time.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

# --- Video recording -------------------------------------------------------

# If false, no videos are written at all (fastest).  Default OFF for this run
# because online DINOv2 inference is ~4x slower than the ResNet50 baseline and
# video encoding adds non-trivial overhead on top.
: "${VIDEO_ENABLED:=false}"

# If true, only episodes where the agent FAILED (success<0.5) get a video.
: "${VIDEO_FAILED_ONLY:=false}"

# Frames per second for the saved mp4 files.
: "${VIDEO_FPS:=10}"

# If true, overlays the top-down map + trajectory + collisions onto each frame.
: "${VIDEO_RENDER_TOP_DOWN:=true}"

# --- Output layout ---------------------------------------------------------

: "${OUT_ROOT:=data/eval_out/dinov2_cached_ckpt10}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING
