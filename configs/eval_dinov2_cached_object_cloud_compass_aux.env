# =============================================================================
# Eval config for the online-trained DINOv2-cached + ego-object-cloud IL
# checkpoint with the goal-compass auxiliary loss head, on the single-scene
# MP3D 6-cat subset.  Source'd by scripts/eval_il_mp3d_1scene_full.sh.
#
# The variant evaluated here is trained by reading precomputed DINOv2 CLS
# features from data/dinov2_cache/<scene>/<episode_id>.pt AND the live online
# EgoObjectCloudSensor (computed from sim depth+semantic each step; no cloud
# cache).  The point-transformer is extended with a 12-D compass-prediction
# head supervised against the privileged GoalCompassSensor.
#
# For *eval* we do NOT use the DINOv2 cache (val has no precomputed features);
# instead we evaluate via the online DINOv2 encoder + the same live
# EgoObjectCloudSensor.  The DINOv2 path runs the exact same
# resize+center_crop (configured via dinov2_resize_h/w; default 252x252,
# patch-aligned to 14) + ImageNet preprocessing and the same frozen
# facebook/dinov2-base backbone that built the cache, so this is apples-to-
# apples with the cached training run.  The policy auto-detects the absence of
# CACHED_DINOV2_SENSOR via the observation space and falls back to live
# DINOv2 inference; the object-cloud encoder branch is unchanged because
# ego_object_cloud is still present.  GOAL_COMPASS_SENSOR is included so the
# GT compass panel appears in eval videos alongside the predicted one.
# =============================================================================

# Online-DINOv2 + object-cloud experiment config (no CACHED_DINOV2_SENSOR in
# the underlying task yaml; EGO_OBJECT_CLOUD_SENSOR stays in online mode
# because we do not override its CACHE_ROOT below).  Trainable weights come
# from EVAL_CKPT, frozen DINOv2 weights are pulled from HuggingFace at
# construction time.
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_object_cloud.yaml}"

# Final checkpoint from the online + compass-aux training run.
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_object_cloud_compass_aux/objectnav_il/mp3d_1scene_6cat_dinov2_object_cloud_compass_aux/ckpt.10.pth}"

: "${EVAL_SPLITS:=train val}"
: "${TEST_EPISODE_COUNT:=-1}"
: "${NUM_ENVIRONMENTS:=1}"

# Match the existing cached-cloud eval setup so numbers are comparable.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

: "${VIDEO_ENABLED:=true}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

: "${OUT_ROOT:=data/eval_out/dinov2_cached_object_cloud_compass_aux_ckpt10}"

# Architecture overrides required by this checkpoint -- always appended to
# whatever the user passes via EXTRA_OPTS so the user can supply per-run
# tweaks (e.g. POLICY.RGB_ENCODER.use_augmentations_test_time False) without
# having to re-type these.  Appending at the end means YACS applies the
# architecture overrides last, so the user can never accidentally turn off
# compass_aux_loss or restore the wrong sensor list.
#
# Why each override is needed:
#   - compass_aux_loss True: must match the trained checkpoint architecture
#     (12-D compass head, goal-conditioned encoder, compass_proj into GRU).
#   - TASK_CONFIG.TASK.SENSORS: drops CACHED_DINOV2_SENSOR (val episodes have
#     no precomputed features) and adds GOAL_COMPASS_SENSOR for the GT panel.
#
# Note: unlike the oracle-cloud sibling env file we do NOT override
# EGO_OBJECT_CLOUD_SENSOR.CACHE_ROOT or the top-level SENSORS list, because:
#   - the cloud must be built online (matches training -- no per-scene NPZ
#     cache was used here), and
#   - depth + semantic agent-level sensors must stay enabled so the online
#     cloud sensor has something to project, which is the default in the
#     underlying objectnav_mp3d_object_cloud.yaml task config.
EXTRA_OPTS="${EXTRA_OPTS:-} POLICY.OBJECT_CLOUD_ENCODER.compass_aux_loss True TASK_CONFIG.TASK.SENSORS [\"OBJECTGOAL_SENSOR\",\"COMPASS_SENSOR\",\"GPS_SENSOR\",\"EGO_OBJECT_CLOUD_SENSOR\",\"GOAL_COMPASS_SENSOR\"]"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING EXTRA_OPTS
