# =============================================================================
# Easy-to-edit config for evaluating the DINOv2-cached + goal-compass IL
# checkpoint on the single-scene MP3D 6-cat subset.  Source'd by
# scripts/eval_il_mp3d_1scene_full.sh.
#
# The cached-GC variant is trained by reading precomputed DINOv2 CLS features
# from data/dinov2_cache/17DRP5sb8fy/<episode_id>.pt AND the live oracle
# GoalCompassSensor (which is cheap and needs no cache).
#
# For *eval* we do NOT use the DINOv2 cache (we don't have val features);
# instead we evaluate via the online DINOv2 encoder + live goal-compass, which
# runs the exact same center_crop(476,630) + ImageNet preprocessing and the
# same frozen facebook/dinov2-base backbone that built the cache, so this is
# apples-to-apples with the cached training run.
# =============================================================================

# Use the online-DINOv2 + goal-compass experiment config (no
# CACHED_DINOV2_SENSOR; GOAL_COMPASS_SENSOR is still enabled).  Trainable
# weights come from EVAL_CKPT, frozen DINOv2 weights are pulled from
# HuggingFace at construction time.
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_goalcompass.yaml}"

# Final checkpoint from the DINOv2-cached + goal-compass run.
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_cached_gc/objectnav_il/mp3d_1scene_6cat_dinov2_cached_gc/ckpt.10.pth}"

# Which splits to evaluate on.
: "${EVAL_SPLITS:=train val}"

# How many episodes per split.  -1 = all (302 for train, 53 for val).
: "${TEST_EPISODE_COUNT:=-1}"

# Concurrent habitat-sim envs during eval.  Keep at 1 so the VectorEnv episode
# iterator doesn't silently drop episodes at split boundaries.
: "${NUM_ENVIRONMENTS:=1}"

# --- Task-config overrides (CRITICAL for a meaningful eval) ----------------
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

# --- Video recording -------------------------------------------------------
: "${VIDEO_ENABLED:=false}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

# --- Output layout ---------------------------------------------------------
: "${OUT_ROOT:=data/eval_out/dinov2_cached_gc_ckpt10}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING
