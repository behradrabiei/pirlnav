# =============================================================================
# Easy-to-edit config for evaluating the DINOv2-cached + ego-object-cloud IL
# checkpoint on the single-scene MP3D 6-cat subset.  Source'd by
# scripts/eval_il_mp3d_1scene_full.sh.
#
# The cached-object-cloud variant is trained by reading precomputed DINOv2 CLS
# features from data/dinov2_cache/17DRP5sb8fy/<episode_id>.pt AND the live
# online EgoObjectCloudSensor (computed from sim depth+semantic each step; no
# cache).
#
# For *eval* we do NOT use the DINOv2 cache (val has no precomputed features);
# instead we evaluate via the online DINOv2 encoder + the same live
# EgoObjectCloudSensor.  The DINOv2 path runs the exact same center_crop(476,
# 630) + ImageNet preprocessing and the same frozen facebook/dinov2-base
# backbone that built the cache, so this is apples-to-apples with the cached
# training run.  The policy auto-detects the absence of the
# CACHED_DINOV2_SENSOR via the observation space and falls back to live DINOv2
# inference; the object-cloud encoder branch is unchanged because
# ego_object_cloud is still present.
# =============================================================================

# Online-DINOv2 + object-cloud experiment config (no CACHED_DINOV2_SENSOR;
# EGO_OBJECT_CLOUD_SENSOR is still enabled).  Trainable weights come from
# EVAL_CKPT, frozen DINOv2 weights are pulled from HuggingFace at construction
# time (they were not serialized into the checkpoint since they were frozen
# during training).
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_object_cloud.yaml}"

# Final checkpoint from the DINOv2-cached + object-cloud run (update 20000).
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_cached_object_cloud/objectnav_il/mp3d_1scene_6cat_dinov2_cached_object_cloud/ckpt.10.pth}"

# Which splits to evaluate on.
# "train" = episodes the model trained on (measures overfit).
# "val"   = held-out episodes from same scene (measures generalisation).
: "${EVAL_SPLITS:=train val}"

# How many episodes per split.  -1 = all (302 for train, 53 for val).
: "${TEST_EPISODE_COUNT:=-1}"

# Concurrent habitat-sim envs during eval.  Keep at 1 so the VectorEnv episode
# iterator doesn't silently drop episodes at split boundaries.
: "${NUM_ENVIRONMENTS:=1}"

# --- Task-config overrides (CRITICAL for a meaningful eval) ----------------
# Sliding ON to match how the MP3D demonstrations were recorded; 1.0 m success
# distance for the same reason.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

# --- Video recording -------------------------------------------------------
# ON by default for this env file.  The eval video automatically gets the
# top-down ego object cloud panel next to the RGB panel (driven by
# observations_to_image in pirlnav/utils/utils.py whenever ego_object_cloud
# is in the observation dict).
: "${VIDEO_ENABLED:=true}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

# --- Output layout ---------------------------------------------------------

: "${OUT_ROOT:=data/eval_out/dinov2_cached_object_cloud_ckpt10}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING
