# =============================================================================
# Eval config for the oracle-trained DINOv2 + object-cloud checkpoint, with
# the object cloud constructed *online* at eval time (generalization test --
# the policy was trained on ground-truth clouds, here it must use a cloud
# built from live depth + semantic).  Source'd by
# scripts/eval_il_mp3d_1scene_full.sh.
#
# Differs from eval_dinov2_oracle_object_cloud.env only in EXTRA_OPTS: with
# CACHE_ROOT unset, EgoObjectCloudSensor falls back to its online branch
# (depth/semantic must therefore stay in AGENT_0.SENSORS, which is the
# default in the underlying objectnav_mp3d_object_cloud.yaml).
# =============================================================================

: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_object_cloud.yaml}"

# Same oracle-trained checkpoint as the cached-mode eval -- comparing apples
# to apples, only the cloud source at eval time differs.
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_oracle_object_cloud/objectnav_il/mp3d_1scene_6cat_dinov2_oracle_object_cloud/ckpt.10.pth}"

: "${EVAL_SPLITS:=train val}"
: "${TEST_EPISODE_COUNT:=-1}"
: "${NUM_ENVIRONMENTS:=1}"

: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

: "${VIDEO_ENABLED:=true}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

: "${OUT_ROOT:=data/eval_out/dinov2_oracle_object_cloud_online_ckpt10}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING
