# =============================================================================
# Easy-to-edit config for evaluating a trained IL checkpoint on the single-scene
# MP3D subset.  Source'd by scripts/eval_il_mp3d_1scene_full.sh.
#
# Change any of the values below and re-run the launcher -- no code or YAML
# edits needed.
# =============================================================================

# Each value below is set with `:=` so that a variable already present in the
# environment (e.g. `NUM_ENVIRONMENTS=8 bash scripts/eval_il_mp3d_1scene_full.sh`)
# wins.  To change a default *permanently*, just edit the value here.

# Checkpoint to evaluate.  ckpt.9 is the best available "final" weight from the
# overfit_v1 run (~18k/20k updates, action_loss already 0.000 by then).
: "${EVAL_CKPT:=data/new_checkpoints/objectnav_il/overfit_v1/ckpt.9.pth}"

# Which splits to evaluate on.  Space-separated subset of: train  val
# "train" = episodes the model trained on (measures overfit).
# "val"   = held-out episodes from same scene (measures generalisation).
: "${EVAL_SPLITS:=train val}"

# How many episodes per split.  -1 = all (302 for train, 53 for val).
: "${TEST_EPISODE_COUNT:=-1}"

# Concurrent habitat-sim envs during eval.  Higher = faster, more GPU mem.
: "${NUM_ENVIRONMENTS:=2}"

# --- Task-config overrides (CRITICAL for a meaningful eval) ----------------
#
# The demonstrations in our MP3D subset were recorded against Habitat's
# standard ObjectNav task: 1.0 m success threshold and sliding-on collision
# handling.  The upstream PIRLNav YAML shipped with this repo has
# SUCCESS_DISTANCE=0.1 and ALLOW_SLIDING=False, which makes the expert
# demonstrations themselves fail ~75% of the time in our sim (verified via
# scripts/diagnose_expert_replay.py).  Setting these to the recording-time
# values recovers the true behaviour ceiling.  Flip them if you intentionally
# want to grade against the stricter spec.
#
# Leave as empty string to fall back to whatever the YAML declares.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

# --- Video recording -------------------------------------------------------

# If false, no videos are written at all (fastest).
: "${VIDEO_ENABLED:=true}"

# If true, only episodes where the agent FAILED (success<0.5) get a video.
# Useful for debugging failure modes without drowning in successful rollouts.
: "${VIDEO_FAILED_ONLY:=false}"

# Frames per second for the saved mp4 files.
: "${VIDEO_FPS:=10}"

# If true, overlays the top-down map + trajectory + collisions onto each frame
# (adds a small per-step sim overhead but does NOT affect inference-time metric).
: "${VIDEO_RENDER_TOP_DOWN:=true}"

# --- Output layout ---------------------------------------------------------

# Root directory for this eval run.  Per-split subfolders (videos/, tb/) are
# created automatically beneath it.
: "${OUT_ROOT:=data/eval_out/overfit_v1_ckpt9}"

export EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING
