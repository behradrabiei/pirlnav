# =============================================================================
# Eval config for the DINOv2-cached @ 252 + online ego-object-cloud IL
# checkpoint on the single-scene MP3D 6-cat subset.  Source'd by
# scripts/eval_il_mp3d_1scene_full.sh.
#
# The variant evaluated here was trained by reading precomputed DINOv2 CLS
# features from data/dinov2_cache_poses_252_poses/<scene>/<episode_id>.pt
# (252x252, pose-replay precompute) AND the live online EgoObjectCloudSensor
# (computed from sim depth+semantic each step; no cloud cache).  Rollout
# collection used IL.BehaviorCloning.REPLAY_MODE=poses (teleport to recorded
# agent_state).  No compass auxiliary loss or GoalCompassSensor.
#
# For *eval* we do NOT use the DINOv2 cache (val split has no cache; eval must
# also work on unseen episodes).  Instead we evaluate via the online DINOv2
# encoder + the same live EgoObjectCloudSensor, which runs the exact same
# resize-to-252x252 + ImageNet preprocessing and the same frozen
# facebook/dinov2-base backbone that built the cache.
#
# IMPORTANT: do NOT add EGO_OBJECT_CLOUD_SENSOR.CACHE_ROOT or SENSORS
# ["RGB_SENSOR"] via EXTRA_OPTS -- that would silently switch eval to oracle
# mode or break online cloud accumulation (depth + semantic must stay enabled).
# Unlike the compass-aux sibling, no compass-related EXTRA_OPTS are needed here.
# =============================================================================

# Online-DINOv2 + object-cloud experiment config (no CACHED_DINOV2_SENSOR;
# EGO_OBJECT_CLOUD_SENSOR stays in online mode because we do not override its
# CACHE_ROOT below).  Trainable weights come from EVAL_CKPT; frozen DINOv2
# weights are pulled from HuggingFace at construction time.
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_object_cloud.yaml}"

# Final checkpoint from the 252 pose-replay cached + online-cloud run.
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_cached_252_online_object_cloud/objectnav_il/mp3d_1scene_6cat_dinov2_cached_252_online_object_cloud/ckpt.10.pth}"

# Which splits to evaluate on.
# "train" = episodes the model trained on (measures overfit).
# "val"   = held-out episodes from same scene (measures generalisation).
: "${EVAL_SPLITS:=train val}"

# How many episodes per split.  -1 = all (302 for train, 53 for val).
: "${TEST_EPISODE_COUNT:=-1}"

# Concurrent habitat-sim envs during eval.  Keep at 1 so the VectorEnv
# episode iterator doesn't silently drop episodes at split boundaries.
: "${NUM_ENVIRONMENTS:=1}"

# --- Task-config overrides (CRITICAL for a meaningful eval) ----------------
# Match the training-time demonstration recording: 1.0m success distance,
# sliding enabled.  Pose-replay training bypasses sim physics, so the policy
# never saw sliding during training -- but eval uses discrete actions through
# sim physics, and we want to compare to what the expert demos achieved.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

# --- Video recording -------------------------------------------------------

# Default OFF because online DINOv2 inference is slow and video encoding adds
# overhead.  Set VIDEO_ENABLED=true on the CLI to record the object-cloud panel
# (observations_to_image renders ego_object_cloud next to RGB when enabled).
: "${VIDEO_ENABLED:=false}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

# --- Output layout ---------------------------------------------------------

: "${OUT_ROOT:=data/eval_out/dinov2_cached_252_online_object_cloud_ckpt10}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING
