# =============================================================================
# Eval config for the oracle-trained DINOv2 + semantic-map checkpoint, with
# the ground-truth per-scene semantic map loaded at eval time (matches train).
# Source'd by scripts/eval_il_mp3d_1scene_full.sh.
#
# Differs from eval_dinov2_oracle_semmap_online.env only in EXTRA_OPTS: here
# the SemanticMapSensor reads a precomputed npz; the online companion drops
# the cache and accumulates the map from depth+semantic at runtime.
# =============================================================================

# Same eval-time experiment yaml the cached-semmap eval uses: live DINOv2
# encoder (no CACHED_DINOV2_SENSOR), SemanticMapSensor still enabled.  The
# policy auto-detects the absence of the cached DINOv2 sensor and falls back
# to live DINOv2 inference; the map encoder branch is unchanged because
# semantic_map is still present.  We flip the sensor into cached mode via
# EXTRA_OPTS below.
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_semmap.yaml}"

# Final checkpoint from the oracle-semmap training run (update 20000).
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_oracle_semmap/objectnav_il/mp3d_1scene_6cat_dinov2_oracle_semmap/ckpt.10.pth}"

: "${EVAL_SPLITS:=train val}"
: "${TEST_EPISODE_COUNT:=-1}"
: "${NUM_ENVIRONMENTS:=1}"

# Match the existing cached-semmap eval setup so numbers are comparable.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

: "${VIDEO_ENABLED:=true}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

: "${OUT_ROOT:=data/eval_out/dinov2_oracle_semmap_ckpt10}"

# Switch the sensor into cached mode and drop DEPTH/SEMANTIC framebuffer
# passes (cached mode never reads them).  Note: we override top-level
# SENSORS, not TASK_CONFIG.SIMULATOR.AGENT_0.SENSORS -- habitat-lab's
# env_utils.py copies the former into the latter, silently undoing the
# bottom-level override.  Test-time augmentation is left at the policy
# default, matching the convention of the other eval_*.env files.
: "${EXTRA_OPTS:=TASK_CONFIG.TASK.SEMANTIC_MAP_SENSOR.CACHE_ROOT data/semantic_maps/mp3d SENSORS [\"RGB_SENSOR\"]}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING EXTRA_OPTS
