# =============================================================================
# Eval config for the DINOv2-cached @ 252 + oracle semantic-map IL checkpoint
# on the single-scene MP3D 6-cat subset.  Source'd by
# scripts/eval_il_mp3d_1scene_full.sh.
#
# The variant evaluated here was trained by reading precomputed DINOv2 CLS
# features from data/dinov2_cache_poses_252_poses/<scene>/<episode_id>.pt
# (252x252, pose-replay precompute) AND the oracle SemanticMapSensor (per-scene
# NPZ at data/semantic_maps/mp3d/<scene>/<scene>.npz).  Rollout collection used
# IL.BehaviorCloning.REPLAY_MODE=poses (teleport to recorded agent_state).
#
# For *eval* we do NOT use the DINOv2 cache (val split has no cache; eval must
# also work on unseen episodes).  Instead we evaluate via the online DINOv2
# encoder + the same oracle NPZ semantic map as training, which runs the exact
# same resize-to-252x252 + ImageNet preprocessing and the same frozen
# facebook/dinov2-base backbone that built the cache.
# =============================================================================

# Online-DINOv2 + semantic-map experiment config (no CACHED_DINOV2_SENSOR;
# SemanticMapSensor is flipped into cached/oracle mode via EXTRA_OPTS below).
# Its yaml pins dinov2_resize_h/w = 252.  Policy weights come from EVAL_CKPT;
# frozen DINOv2 weights are pulled from HuggingFace at construction time.
: "${CONFIG:=configs/experiments/il_objectnav_mp3d_dinov2_semmap.yaml}"

# Final checkpoint from the 252 pose-replay cached + oracle-semmap run.
: "${EVAL_CKPT:=data/new_checkpoints_dinov2_cached_252_oracle_semmap/objectnav_il/mp3d_1scene_6cat_dinov2_cached_252_oracle_semmap/ckpt.10.pth}"

# Which splits to evaluate on.
# "train" = episodes the model trained on (measures overfit).
# "val"   = held-out episodes from same scene (measures generalisation).
: "${EVAL_SPLITS:=train val}"

# How many episodes per split.  -1 = all (302 for train, 53 for val).
: "${TEST_EPISODE_COUNT:=-1}"

# Concurrent habitat-sim envs during eval.  Keep at 1 so the VectorEnv
# episode iterator doesn't silently drop episodes at split boundaries.
: "${NUM_ENVIRONMENTS:=1}"

# --- Task-config overrides (CRITICAL for a meaningful eval) ----------------
# Match the training-time demonstration recording: 1.0m success distance,
# sliding enabled.  Pose-replay training bypasses sim physics, so the policy
# never saw sliding during training -- but eval uses discrete actions through
# sim physics, and we want to compare to what the expert demos achieved.
: "${SUCCESS_DISTANCE:=1.0}"
: "${ALLOW_SLIDING:=True}"

# --- Video recording -------------------------------------------------------

: "${VIDEO_ENABLED:=true}"
: "${VIDEO_FAILED_ONLY:=false}"
: "${VIDEO_FPS:=10}"
: "${VIDEO_RENDER_TOP_DOWN:=true}"

# --- Output layout ---------------------------------------------------------

: "${OUT_ROOT:=data/eval_out/dinov2_cached_252_oracle_semmap_ckpt10}"

# Switch the sensor into oracle/cached mode and drop DEPTH/SEMANTIC framebuffer
# passes (cached mode never reads them).  Note: we override top-level SENSORS,
# not TASK_CONFIG.SIMULATOR.AGENT_0.SENSORS -- habitat-lab's env_utils.py
# copies the former into the latter, silently undoing the bottom-level override.
: "${EXTRA_OPTS:=TASK_CONFIG.TASK.SEMANTIC_MAP_SENSOR.CACHE_ROOT data/semantic_maps/mp3d SENSORS [\"RGB_SENSOR\"]}"

export CONFIG EVAL_CKPT EVAL_SPLITS TEST_EPISODE_COUNT NUM_ENVIRONMENTS \
       VIDEO_ENABLED VIDEO_FAILED_ONLY VIDEO_FPS VIDEO_RENDER_TOP_DOWN OUT_ROOT \
       SUCCESS_DISTANCE ALLOW_SLIDING EXTRA_OPTS
